# moyu web (apps/web) runtime env — loaded via `env_file` in docker-compose.
# Copy to docker/web.env.
#
# Public config is BAKED AT BUILD from the compose `build.args` (PUBLIC_*).
# This file is for the "build once, configure at runtime" path: Nitro overrides
# any runtimeConfig.public key from the canonical NUXT_PUBLIC_<key> env at
# container start. Uncomment + set to override the baked values without a
# rebuild. (These are public, not secret — they ship to the browser.)

NUXT_PUBLIC_API_BASE=https://www.moyu.moe/api/v1
NUXT_PUBLIC_OAUTH_SERVER_URL=https://oauth.kungal.com/api/v1
NUXT_PUBLIC_OAUTH_WEB_URL=https://oauth.kungal.com
NUXT_PUBLIC_OAUTH_CLIENT_ID=df3ff6008d740bfacbe46aa8cf483cf2
NUXT_PUBLIC_OAUTH_REDIRECT_URI=https://www.moyu.moe/auth/callback
