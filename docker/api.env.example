# moyu API (apps/api) runtime env — loaded via `env_file` in docker-compose.
# Copy to docker/api.env and fill the secrets. NEVER commit the real file
# (.dockerignore + .gitignore keep docker/*.env out of images and git).
#
# Hosts are HUB SERVICE NAMES (resolved on kun-oauth-admin_default network),
# not localhost. Container ports, not host ports.

KUN_SERVER_PORT=5214
KUN_SERVER_MODE=prod

# Shared Postgres (hub). Database kungalgame_patch must exist — add it to the
# hub's docker/initdb.d (CREATE DATABASE kungalgame_patch;).
KUN_DATABASE_URL=postgresql://postgres:191007@postgres:5432/kungalgame_patch?sslmode=disable

# Shared Redis (hub)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 鲲 Galgame OAuth (hub `oauth` service). CLIENT_SECRET is a SECRET — rotate it.
OAUTH_SERVER_URL=http://oauth:9277/api/v1
OAUTH_CLIENT_ID=df3ff6008d740bfacbe46aa8cf483cf2
OAUTH_CLIENT_SECRET=__SET_ME__
# Browser-facing callback (host port of the web service)
OAUTH_REDIRECT_URI=http://localhost:15011/auth/callback

# Galgame Wiki Service (hub `galgame` service)
KUN_GALGAME_WIKI_BASE_URL=http://galgame:9280/api

# image_service (hub `image` service). CDN_BASE is REQUIRED in prod mode
# (the app fails fast if unset) and MUST equal the public URL the frontend
# resolves hashes against — see docker/README.md §image_service.
KUN_IMAGE_SERVICE_BASE_URL=http://image:9278
KUN_IMAGE_CDN_BASE=http://localhost:15002/kun-images
# Optional: dedicated image client creds; blank → reuse OAUTH_CLIENT_ID/SECRET.
KUN_IMAGE_OAUTH_CLIENT_ID=
KUN_IMAGE_OAUTH_CLIENT_SECRET=

# S3 — Backblaze B2, patch resource files (NOT image_service). SECRETS.
KUN_VISUAL_NOVEL_S3_STORAGE_ACCESS_KEY_ID=__SET_ME__
KUN_VISUAL_NOVEL_S3_STORAGE_SECRET_ACCESS_KEY=__SET_ME__
KUN_VISUAL_NOVEL_S3_STORAGE_BUCKET_NAME=kun-galgame-patch
KUN_VISUAL_NOVEL_S3_STORAGE_ENDPOINT=https://s3.us-east-005.backblazeb2.com
KUN_VISUAL_NOVEL_S3_STORAGE_URL=https://oss.moyu.moe
KUN_VISUAL_NOVEL_S3_STORAGE_REGION=us-east-005

# Email (SMTP). PASSWORD is a SECRET.
KUN_VISUAL_NOVEL_EMAIL_HOST=tuesday.mxrouting.net
KUN_VISUAL_NOVEL_EMAIL_PORT=587
KUN_VISUAL_NOVEL_EMAIL_ACCOUNT=auth@moyu.moe
KUN_VISUAL_NOVEL_EMAIL_PASSWORD=__SET_ME__

# CORS — the web origin (host port). Add the real prod domain in production.
CORS_ALLOW_ORIGINS=http://localhost:15011
