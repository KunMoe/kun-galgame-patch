# ─────────────────────────────────────────────────────────────────────────────
# moyu web (apps/web, Nuxt 4 SSR) — LOCAL DEV env. Copy to apps/web/.env.
#
# Every key is read by nuxt.config.ts (runtimeConfig, process.env.*); values point
# at the kun-galgame-infra dev stack. The Nuxt dev server runs on 127.0.0.1:6969.
# See ../../kun-galgame-infra/docs/dev-environment.md.
# ─────────────────────────────────────────────────────────────────────────────

# This project's Go Fiber API (moyu-api on :5214) — the browser-facing base.
KUN_VISUAL_NOVEL_NUXT_PUBLIC_API_BASE = "http://127.0.0.1:5214/api/v1"

# 鲲 Galgame OAuth (dev stack) — two URLs:
#   SERVER_URL : API base for token exchange + /users/batch (oauth service :9277).
#   WEB_URL    : the account-center web app for redirects to /oauth/authorize,
#                /register, /profile (the infra apps/web Nuxt on :9420 in dev).
#   CLIENT_ID  : moyu's registered client (public dev value; the browser only ever
#                sends the id + PKCE, never a secret).
NUXT_PUBLIC_KUN_OAUTH_SERVER_URL = "http://127.0.0.1:9277/api/v1"
NUXT_PUBLIC_KUN_OAUTH_WEB_URL = "http://127.0.0.1:9420"
NUXT_PUBLIC_KUN_OAUTH_CLIENT_ID = "df3ff6008d740bfacbe46aa8cf483cf2"
NUXT_PUBLIC_KUN_OAUTH_REDIRECT_URI = "http://127.0.0.1:6969/auth/callback"

# 鲲 Galgame Wiki public origin — the browser jumps to ${origin}/galgame/:id and
# /edit/draft reads ${origin}/api/galgame/:id. Dev = the wiki Nuxt on :9421.
NUXT_PUBLIC_WIKI_ORIGIN = "http://127.0.0.1:9421"

# image_service CDN base → the dev stack's read-through proxy (:9290); the
# /image/:hash route resolves content tokens to {base}/<aa>/<bb>/<hash>.webp. MUST
# match the backend KUN_IMAGE_CDN_BASE (no trailing slash).
NUXT_PUBLIC_IMAGE_BED = "http://127.0.0.1:9290"

# SSR-side API base (in-container service name, e.g. http://moyu-api:5214/api/v1).
# Leave empty for local air dev — the dual-base reader falls back to the public base.
# NUXT_API_BASE_SSR = ""
