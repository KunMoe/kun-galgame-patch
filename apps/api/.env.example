# Server
KUN_SERVER_PORT = "5214"
KUN_SERVER_MODE = "dev"

# PostgreSQL
KUN_DATABASE_URL = "postgresql://postgres:kunloveren@localhost:5432/kungalgame_patch?sslmode=disable"

# Redis
REDIS_HOST = "127.0.0.1"
REDIS_PORT = "6379"
REDIS_PASSWORD = ""

# 鲲 Galgame OAuth (API on :9277, user-facing frontend on :9420)
OAUTH_SERVER_URL = "http://127.0.0.1:9277/api/v1"
OAUTH_CLIENT_ID = "your-client-id"
OAUTH_CLIENT_SECRET = "your-client-secret"
OAUTH_REDIRECT_URI = "http://127.0.0.1:5213/auth/callback"

# S3 Storage — Backblaze B2, used for patch resource files.
# Images live in a separate R2 bucket served by image_service (KUN_IMAGE_*).
# ENDPOINT = S3-API origin (e.g. https://s3.us-east-005.backblazeb2.com).
# URL      = public download prefix; leave empty in dev to use the raw
#            ENDPOINT/BUCKET_NAME, set to a CDN domain (e.g. https://oss.moyu.moe)
#            in prod so downloads don't hit B2 directly.
KUN_VISUAL_NOVEL_S3_STORAGE_ACCESS_KEY_ID = ""
KUN_VISUAL_NOVEL_S3_STORAGE_SECRET_ACCESS_KEY = ""
KUN_VISUAL_NOVEL_S3_STORAGE_BUCKET_NAME = ""
KUN_VISUAL_NOVEL_S3_STORAGE_ENDPOINT = ""
KUN_VISUAL_NOVEL_S3_STORAGE_URL = ""
KUN_VISUAL_NOVEL_S3_STORAGE_REGION = ""

# Email (SMTP)
KUN_VISUAL_NOVEL_EMAIL_HOST = ""
KUN_VISUAL_NOVEL_EMAIL_PORT = "587"
KUN_VISUAL_NOVEL_EMAIL_ACCOUNT = ""
KUN_VISUAL_NOVEL_EMAIL_PASSWORD = ""

# Galgame Wiki Service
KUN_GALGAME_WIKI_BASE_URL = "http://127.0.0.1:9280/api"

# image_service (centralized hash-addressed image store; screenshot/editor uploads).
# REQUIRED in prod (KUN_SERVER_MODE=prod) — the app fails fast if unset there, so
# uploads/CDN can't silently fall back to these localhost dev values.
#   BASE_URL = image_service API origin (no trailing slash).
#   CDN_BASE = public CDN prefix serving the /img/<aa>/<bb>/<hash>[_variant].webp tree.
# CLIENT_ID / CLIENT_SECRET are optional: when blank, the app reuses the OAuth
# client credentials above (image_service shares OAuth's oauth_client registry).
KUN_IMAGE_SERVICE_BASE_URL = "http://127.0.0.1:9278"
KUN_IMAGE_CDN_BASE = "http://127.0.0.1:9000/kun-images-dev"
KUN_IMAGE_OAUTH_CLIENT_ID = ""
KUN_IMAGE_OAUTH_CLIENT_SECRET = ""

# CORS
CORS_ALLOW_ORIGINS = "http://127.0.0.1:5213,http://127.0.0.1:6969"
