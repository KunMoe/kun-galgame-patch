# ─────────────────────────────────────────────────────────────────────────────
# moyu API (apps/api) — LOCAL DEV env. Copy to apps/api/.env (godotenv loads it).
#
# Turnkey against the kun-galgame-infra dev stack. Onboarding is three steps:
#   1. cd ../kun-galgame-infra && docker compose -f docker-compose.dev.yml up -d
#   2. (optional) ./scripts/refresh-dev-db.sh        # real-shaped, desensitised data
#   3. cp apps/api/.env.example apps/api/.env         # this file, then `pnpm dev`
#
# Every URL points at the dev stack's host-network ports (identical to prod
# 9277-9283). The OAuth client id + secret are the PUBLIC dev derivation (裁定 3)
# refresh-dev-db bakes into oauth_clients — a client presenting the plaintext
# `dev-secret-<client_id>` authenticates. See
# ../kun-galgame-infra/docs/dev-environment.md.
# ─────────────────────────────────────────────────────────────────────────────

# Server
KUN_SERVER_PORT = "5214"
KUN_SERVER_MODE = "dev"

# PostgreSQL — moyu's own DB on the dev box's host Postgres (the dev source of
# truth; NOT a compose service). user postgres / password 191007.
KUN_DATABASE_URL = "postgresql://postgres:191007@127.0.0.1:5432/kungalgame_patch?sslmode=disable"

# Redis (dev stack :6379)
REDIS_HOST = "127.0.0.1"
REDIS_PORT = "6379"
REDIS_PASSWORD = ""

# 鲲 Galgame OAuth (dev stack — API on :9277, account-center frontend on :9420).
# client_id = moyu's registered client; client_secret = its public dev derivation.
OAUTH_SERVER_URL = "http://127.0.0.1:9277/api/v1"
OAUTH_CLIENT_ID = "df3ff6008d740bfacbe46aa8cf483cf2"
OAUTH_CLIENT_SECRET = "dev-secret-df3ff6008d740bfacbe46aa8cf483cf2"
OAUTH_REDIRECT_URI = "http://127.0.0.1:6969/auth/callback"

# NextMoe catalog service (dev stack catalog — co-hosts the galgame surface
# since infra W2/W5). HOST base only (no /api|/internal); the galgame client
# derives {base}/internal (internal-tier read face + S2S message feed, X-API-Key)
# and {base}/api (legacy: writes / submissions). The dev default is the local
# phase2 catalog instance (:19281); a plain `pnpm dev` catalog is :9281.
KUN_NEXTMOE_API_BASE = "http://127.0.0.1:19281"
# Internal-tier read-face key. REQUIRED: the empty-key rollback to legacy /api
# was retired (open-API phase 2 wave 05), so the server fails fast at startup
# when the base is set but this key is empty. Mint a local nm_ key for dev.
KUN_NEXTMOE_API_KEY = ""

# image_service (dev stack image :9278) — content-addressed image store
# (screenshot / editor / cover uploads).
#   BASE_URL = image_service API origin (no trailing slash).
#   CDN_BASE = the dev stack's read-through proxy (:9290): serves the
#              <aa>/<bb>/<hash>.webp tree from local MinIO and falls back to the
#              prod public CDN on a miss, so unseeded images still render.
# CLIENT_ID / CLIENT_SECRET are optional — blank reuses the OAuth client creds
# above (image_service shares OAuth's oauth_client registry).
KUN_IMAGE_SERVICE_BASE_URL = "http://127.0.0.1:9278"
KUN_IMAGE_CDN_BASE = "http://127.0.0.1:9290"
KUN_IMAGE_OAUTH_CLIENT_ID = ""
KUN_IMAGE_OAUTH_CLIENT_SECRET = ""

# artifact service (dev stack artifact :9279) — private-bucket large-file
# upload/download (patch resource files; the browser PUTs bytes straight to
# storage, the API drives the init/complete/download JSON calls). CLIENT_ID /
# CLIENT_SECRET are optional — blank reuses the OAuth client creds above.
KUN_ARTIFACT_SERVICE_BASE_URL = "http://127.0.0.1:9279"
KUN_ARTIFACT_OAUTH_CLIENT_ID = ""
KUN_ARTIFACT_OAUTH_CLIENT_SECRET = ""

# Trust & Safety service (dev stack trust :9283) — report intake + enforcement
# callbacks + moderator inbox. OPTIONAL: unset/empty = the integration is inert
# (reports degrade with 未启用, callbacks are rejected). In prod, unset likewise
# disables it (no panic) until infra onboarding (oauth_clients.catalog_site,
# trust.queue_access, subject-kind registration — patch_resource needs
# notify_on_dismiss=true or mod-hidden resources are never restored).
# CALLBACK_SECRET must equal the trust_subject_kind.callback_secret registered
# for moyu's kinds; S2S Basic auth reuses the OAuth client creds above.
KUN_TRUST_BASE_URL = "http://127.0.0.1:9283"
KUN_TRUST_SITE = "moyu"
KUN_TRUST_CALLBACK_SECRET = ""

# CORS — the moyu dev frontends (5213 = legacy next-web, 6969 = current Nuxt web).
CORS_ALLOW_ORIGINS = "http://127.0.0.1:5213,http://127.0.0.1:6969"
