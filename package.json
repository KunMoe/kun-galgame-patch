{
  "name": "kun-galgame-patch-next-fiber",
  "version": "5.1.37",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -F \"./apps/**\" --parallel --stream run dev",
    "dev:web": "pnpm -F @apps/web run dev",
    "dev:api": "pnpm -F @apps/api run dev",
    "build": "pnpm run build:api && pnpm run build:web",
    "build:web": "pnpm -F @apps/web run build",
    "build:api": "pnpm -F @apps/api run build",
    "format": "pnpm -F \"./apps/**\" --parallel run format",
    "lint": "pnpm -F @apps/web run lint",
    "lint:fix": "pnpm -F @apps/web run lint:fix",
    "typecheck": "pnpm -F @apps/web run typecheck",
    "vet": "pnpm -F @apps/api run vet",
    "test:api": "pnpm -F @apps/api run test",
    "sitemap": "esno apps/web/scripts/generateKunSitemap.ts",
    "prod:deploy": "./scripts/deploy.sh",
    "prod:start": "./scripts/start.sh",
    "prod:stop": "./scripts/stop.sh",
    "prod:restart": "./scripts/restart.sh",
    "prod:logs": "pm2 logs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "esno": "^4.8.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "aws-sdk",
      "bcrypt",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
